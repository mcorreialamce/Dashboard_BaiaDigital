#!/bin/bash

# ─────────────────────────────────────────────────────────────────────────────

# LAMCE — Script de deploy para o repositório GitHub

# 

# USO:

# 1. Edite a variável REPO_PATH abaixo com o caminho do seu repo clonado

# 2. Execute:  bash push_to_github.sh

# ─────────────────────────────────────────────────────────────────────────────

# ── EDITE AQUI ────────────────────────────────────────────────────────────────

REPO_PATH=”/caminho/para/seu/repo”          # ex: /home/usuario/lamce-dashboard

# ─────────────────────────────────────────────────────────────────────────────

SOURCE_DIR=”$(cd “$(dirname “$0”)” && pwd)”  # pasta onde este script está

echo “”
echo “══════════════════════════════════════════════════”
echo “  LAMCE — Push para GitHub”
echo “  Repo: $REPO_PATH”
echo “══════════════════════════════════════════════════”
echo “”

# Verifica se o repo existe

if [ ! -d “$REPO_PATH/.git” ]; then
echo “❌  Repositório git não encontrado em: $REPO_PATH”
echo “    Verifique o caminho e tente novamente.”
exit 1
fi

# ── Estrutura de pastas no repo ───────────────────────────────────────────────

echo “📁  Criando estrutura de pastas…”
mkdir -p “$REPO_PATH/backend”
mkdir -p “$REPO_PATH/frontend”
mkdir -p “$REPO_PATH/docs”

# ── Copiar arquivos do backend ────────────────────────────────────────────────

echo “📋  Copiando arquivos do backend…”
cp “$SOURCE_DIR/main.py”        “$REPO_PATH/backend/main.py”
cp “$SOURCE_DIR/inspect_nc.py”  “$REPO_PATH/backend/inspect_nc.py”
cp “$SOURCE_DIR/requirements.txt” “$REPO_PATH/backend/requirements.txt”
cp “$SOURCE_DIR/.env.example”   “$REPO_PATH/.env.example”
cp “$SOURCE_DIR/.gitignore”     “$REPO_PATH/.gitignore”

# ── Copiar dashboard (frontend) ───────────────────────────────────────────────

echo “🎨  Copiando protótipo do dashboard…”

# Ajuste o caminho se os .jsx estiverem em outra pasta

DASHBOARD_SRC=”$(dirname “$SOURCE_DIR”)”
for f in “$DASHBOARD_SRC”/lamce-dashboard*.jsx; do
[ -f “$f” ] && cp “$f” “$REPO_PATH/frontend/” && echo “    ✅  $(basename $f)”
done

# ── Git: add, commit, push ────────────────────────────────────────────────────

cd “$REPO_PATH”

echo “”
echo “🔍  Status atual do repositório:”
git status –short
echo “”

git add .

# Mensagem de commit automática com data

COMMIT_MSG=“feat: LAMCE dashboard - backend FastAPI + protótipo visual

- main.py: API FastAPI com endpoints LCFA, DENS, ABI, timeseries
- inspect_nc.py: ferramenta de inspeção de campos NetCDF
- Dashboard React (lamce-dashboard-v4.jsx): mapa GLM + série temporal
- .gitignore: protege dados .nc e imagens do satélite
- .env.example: template de configuração

Estrutura de disco: /goes/YYYYMMDD/HH/
Freq. atualização: 10 min
Satélite: GOES-19 | Produtos: GLM LCFA, GLM DENS, ABI”

git commit -m “$COMMIT_MSG”

echo “”
echo “🚀  Fazendo push para o GitHub…”
git push

echo “”
echo “══════════════════════════════════════════════════”
echo “  ✅  Concluído! Verifique no GitHub.”
echo “══════════════════════════════════════════════════”
echo “”
